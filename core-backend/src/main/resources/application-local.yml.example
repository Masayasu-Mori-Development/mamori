# ローカル開発環境用設定
# このファイルをコピーして application-local.yml として使用してください

spring:
  datasource:
    url: jdbc:postgresql://localhost:5432/mamori
    username: mamori_user
    password: mamori_pass
    driver-class-name: org.postgresql.Driver

  jpa:
    show-sql: true
    hibernate:
      ddl-auto: validate
    properties:
      hibernate:
        default_schema: core

  flyway:
    schemas: core
    default-schema: core

logging:
  level:
    com.mamori.core: DEBUG
    org.springframework.web: DEBUG
    org.springframework.security: DEBUG
    org.hibernate.SQL: DEBUG
    org.hibernate.type.descriptor.sql.BasicBinder: TRACE

app:
  jwt:
    secret: local-development-secret-key-change-in-production-min-256-bits
    expiration: 86400000
    refresh-expiration: 604800000
