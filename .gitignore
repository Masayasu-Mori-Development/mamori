# ====================
# 機密情報・環境変数
# ====================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks
*secret*
*credential*
secrets/
.aws/

# ====================
# Node.js / React（フロントエンド）
# ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ビルド成果物
frontend/build/
frontend/dist/
frontend/.next/
frontend/out/

# キャッシュ
frontend/.cache/
frontend/.eslintcache
frontend/.stylelintcache

# テストカバレッジ
frontend/coverage/
frontend/.nyc_output/

# ====================
# Kotlin / Gradle（バックエンド）
# ====================
backend/.gradle/
backend/build/
backend/out/
backend/bin/
backend/.kotlinc/

# Gradle関連
.gradle/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties

# Spring Boot
backend/target/
backend/*.log
backend/logs/

# アプリケーション設定（環境別）
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-dev.yml
backend/src/main/resources/application-prod.yml
backend/src/main/resources/application-*.properties
!backend/src/main/resources/application.yml
!backend/src/main/resources/application.properties

# ====================
# Terraform（インフラ）
# ====================
infra/terraform/.terraform/
infra/terraform/.terraform.lock.hcl
infra/terraform/terraform.tfstate
infra/terraform/terraform.tfstate.backup
infra/terraform/*.tfvars
!infra/terraform/*.tfvars.example
infra/terraform/.terraformrc
infra/terraform/crash.log
infra/terraform/override.tf
infra/terraform/override.tf.json
infra/terraform/*_override.tf
infra/terraform/*_override.tf.json

# ====================
# IDE設定
# ====================

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
# .vscode/ ディレクトリはプロジェクト設定として共有
# ただし、個人設定は除外
.vscode/settings.local.json
.vscode/*.log

# Eclipse
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/
nbbuild/
nbdist/
.nb-gradle/

